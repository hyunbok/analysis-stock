# Database
DATABASE_URL=postgresql+asyncpg://cointrader:password@localhost:5432/cointrader
MONGODB_URL=mongodb://cointrader:password@localhost:27017/cointrader?authSource=admin
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# Encryption
EXCHANGE_API_KEY_SECRET=your-aes-256-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Monitoring
SENTRY_DSN=

# App
DEBUG=true
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
